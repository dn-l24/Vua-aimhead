local function createToggle(name, textON, textOFF, defaultState, callback)
    local btn = Instance.new("TextButton")
    local state = defaultState
    btn.Size = UDim2.new(0, 320, 0, 35)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    local function updateView()
        btn.Text = state and textON or textOFF
        btn.BackgroundColor3 = state and Color3.fromRGB(0, 170, 100) or Color3.fromRGB(170, 50, 50)
    end
    updateView()
    btn.MouseButton1Click:Connect(function()
        state = not state
        updateView()
        callback(state)
    end)
    return btn
end

