-- XỬ LÝ DI CHUYỂN ĐỒNG BỘ (DRAGGABLE) MƯỢT MÀ BẰNG TWEEN
local dragging = false
local dragInput, dragStart, startPos, startBtnPos

local function updateMenuPos(input)
    local delta = input.Position - dragStart
    local targetMenuPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    local targetBtnPos = UDim2.new(startBtnPos.X.Scale, startBtnPos.X.Offset + delta.X, startBtnPos.Y.Scale, startBtnPos.Y.Offset + delta.Y)
    
    -- Dùng Tween thời gian cực ngắn (0.05 giây) để loại bỏ hiện tượng giật lắc khi kéo thả trên Mobile
    TweenService:Create(MainMenu, TweenInfo.new(0.05, Enum.EasingStyle.OutQuad), {Position = targetMenuPos}):Play()
    TweenService:Create(MenuButton, TweenInfo.new(0.05, Enum.EasingStyle.OutQuad), {Position = targetBtnPos}):Play()
end

local function handleDrag(guiObject)
    guiObject.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            -- Nếu đang vuốt nội dung bên trong ScrollingFrame thì KHÔNG kích hoạt kéo menu đi chỗ khác
            if UserInputService:GetFocusedTextBox() then return end
            
            dragging = true
            dragStart = input.Position
            startPos = MainMenu.Position
            startBtnPos = MenuButton.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then 
                    dragging = false 
                end
            end)
        end
    end)

    guiObject.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
end

-- Kích hoạt di chuyển khi kéo vùng Tiêu đề (Title) hoặc nút Ẩn/Hiện
handleDrag(Title)
handleDrag(MenuButton)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        updateMenuPos(input)
    end
end)
