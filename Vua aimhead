    uicorner.Parent = container
    
    local label = Instance.new("TextLabel")
    label.Parent = container
    label.Size = UDim2.new(0, 160, 1, 0)
    label.Position = UDim2.new(0, 10, 0, 0)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.SourceSans
    label.TextSize = 13
    label.TextColor3 = Color3.fromRGB(240, 240, 240)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.ZIndex = 4

    local toggleTrack = Instance.new("TextButton")
    toggleTrack.Parent = container
    toggleTrack.Size = UDim2.new(0, 36, 0, 18)
    toggleTrack.Position = UDim2.new(1, -46, 0, 8)
    toggleTrack.Text = ""
    toggleTrack.ZIndex = 4
    
    local trackCorner = Instance.new("UICorner")
    trackCorner.CornerRadius = UDim.new(0, 9)
    trackCorner.Parent = toggleTrack
    
    local toggleCircle = Instance.new("Frame")
    toggleCircle.Parent = toggleTrack
    toggleCircle.Size = UDim2.new(0, 14, 0, 14)
    toggleCircle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    toggleCircle.BorderSizePixel = 0
    toggleCircle.ZIndex = 5
    
    local circleCorner = Instance.new("UICorner")
    circleCorner.CornerRadius = UDim.new(0, 7)
    circleCorner.Parent = toggleCircle

    local state = defaultState
    local function updateView()
        label.Text = (CurrentLanguage == "VN") and labelTexts.VN or labelTexts.EN
        if state then
            toggleTrack.BackgroundColor3 = AccentColor
            toggleTrack.BackgroundTransparency = 0
            toggleCircle.Position = UDim2.new(1, -16, 0, 2)
        else
            toggleTrack.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            toggleTrack.BackgroundTransparency = 0.8
            toggleCircle.Position = UDim2.new(0, 2, 0, 2)
        end
    end

    toggleTrack.MouseButton1Click:Connect(function()
        state = not state
        updateView()
        callback(state)
    end)
    
    table.insert(UI_Elements, updateView)
    updateView()
end

