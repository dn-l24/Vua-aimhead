-- XỬ LÝ KÉO THẢ MENU (DRAG)
local draggingDashboard, dragInputDashboard, dragStartDashboard, startPosDashboard, startBtnPosDashboard

local function updateMenuPos(input)
    local delta = input.Position - dragStartDashboard
    MainMenu.Position = UDim2.new(startPosDashboard.X.Scale, startPosDashboard.X.Offset + delta.X, startPosDashboard.Y.Scale, startPosDashboard.Y.Offset + delta.Y)
    MenuButton.Position = UDim2.new(startBtnPosDashboard.X.Scale, startBtnPosDashboard.X.Offset + delta.X, startBtnPosDashboard.Y.Scale, startBtnPosDashboard.Y.Offset + delta.Y)
end

local function handleDragDashboard(guiObject)
    guiObject.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingDashboard = true
            dragStartDashboard = input.Position
            startPosDashboard = MainMenu.Position
            startBtnPosDashboard = MenuButton.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then draggingDashboard = false end
            end)
        end
    end)
    guiObject.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInputDashboard = input
        end
    end)
end

handleDragDashboard(MainMenu)
handleDragDashboard(MenuButton)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInputDashboard and draggingDashboard then updateMenuPos(input) end
end)
