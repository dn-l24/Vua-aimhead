-- Hàm tạo Nút Bật/Tắt (Toggle) có hiệu ứng chuyển màu mượt
local function createToggle(name, textON, textOFF, defaultState, callback)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Parent = Container
    btn.Size = UDim2.new(0, 210, 0, 35) -- Tăng kích thước nút để dễ chạm trúng hơn
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 13
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.AutoButtonColor = false
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = btn

    local state = defaultState
    local function updateView(instant)
        local targetColor = state and Color3.fromRGB(0, 170, 100) or Color3.fromRGB(170, 50, 50)
        btn.Text = state and textON or textOFF
        if instant then
            btn.BackgroundColor3 = targetColor
        else
            TweenService:Create(btn, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {BackgroundColor3 = targetColor}):Play()
        end
    end
    updateView(true)

    btn.MouseButton1Click:Connect(function()
        state = not state
        updateView(false)
        callback(state)
    end)
    return btn
end

