-- HỆ THỐNG XỬ LÝ KILL AURA
local function resetSwordSize(tool)
    if tool and tool:FindFirstChild("Handle") and OriginalToolData[tool] then
        local handle = tool.Handle
        handle.Size = OriginalToolData[tool].Size
        tool.Grip = OriginalToolData[tool].Grip
        handle.Massless = false
        handle.CanCollide = true
        OriginalToolData[tool] = nil
    end
end

local function stopKillAuraLogic()
    if KillAuraConnection then KillAuraConnection:Disconnect() KillAuraConnection = nil end
    for tool, _ in pairs(OriginalToolData) do resetSwordSize(tool) end
    OriginalToolData = {}
end

local function startKillAuraLogic()
    if KillAuraConnection then return end
    KillAuraConnection = RunService.Heartbeat:Connect(function()
        if not KillAuraEnabled then return end
        local char = LocalPlayer.Character
        if not char then return end

        local equippedTool = char:FindFirstChildOfClass("Tool")
        if equippedTool and equippedTool:FindFirstChild("Handle") then
            local handle = equippedTool.Handle
            if not OriginalToolData[equippedTool] then
                OriginalToolData[equippedTool] = { Size = handle.Size, Grip = equippedTool.Grip }
            end
            
            handle.Size = GIANT_SIZE
            handle.Massless = true
            handle.CanCollide = false
            equippedTool.Grip = CFrame.new(0, 0, -(GIANT_SIZE.Z / 2) - 10)
            equippedTool:Activate()

            if firetouchinterest then
                for _, player in ipairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        firetouchinterest(handle, player.Character.HumanoidRootPart, 0)
                        firetouchinterest(handle, player.Character.HumanoidRootPart, 1)
                    end
                end
            end
        end

        local backpack = LocalPlayer:FindFirstChild("Backpack")
        if backpack then
            for _, item in ipairs(backpack:GetChildren()) do
                if item:IsA("Tool") and OriginalToolData[item] then resetSwordSize(item) end
            end
        end
    end)
end

-- VÒNG LẶP CHÍNH (ĐÃ GỘP TẤT CẢ VÀO 1 VÒNG ĐỂ TỐI ƯU FPS)
RunService.RenderStepped:Connect(function()
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    FOVCircle.Position = screenCenter
    FOVCircle.Radius = FOV_RADIUS
    FOVCircle.Color = FOVColor
    FOVCircle.Visible = AimbotEnabled

    local localCharacter = LocalPlayer.Character
    local localRoot = localCharacter and localCharacter:FindFirstChild("HumanoidRootPart")
    
    local closestAimbotPlayer = nil
    local shortestDistance = math.huge
    local tracerCandidates = {}

    -- Duyệt người chơi cho cả Aimbot và Tracers
    if AimbotEnabled or ESPEnabled then
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer or not player.Character then continue end
            
            local char = player.Character
            local targetPart = char:FindFirstChild(TARGET_PART)
            local root = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")

            if hum and hum.Health > 0 and targetPart and root and char.Parent == Workspace then
                -- Kiểm tra Aimbot
                if AimbotEnabled then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                    if onScreen then
                        local distanceToCenter = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                        if distanceToCenter <= FOV_RADIUS and distanceToCenter < shortestDistance and isVisible(char, targetPart) then
                            closestAimbotPlayer = player
                            shortestDistance = distanceToCenter
                        end
                    end
                end

                -- Thu thập dữ liệu Tracer
                if ESPEnabled and localRoot then
                    local distance = (root.Position - localRoot.Position).Magnitude
                    if distance <= MAX_LINE_DISTANCE then
                        table.insert(tracerCandidates, {Player = player, Distance = distance, TargetPart = targetPart})
                    end
                end
            end
        end
    end

    -- Xử lý Aimbot
    if AimbotEnabled and closestAimbotPlayer then
        local targetPos = closestAimbotPlayer.Character[TARGET_PART].Position
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, targetPos)
    end

    -- Xử lý Tracers
    if ESPEnabled then
        if #tracerCandidates > 1 then
            table.sort(tracerCandidates, function(a, b) return a.Distance < b.Distance end)
        end
        for i = 1, 3 do
            local line = TracerLines[i]
            local candidate = tracerCandidates[i]
            if candidate then
                local screenPos, onScreen = Camera:WorldToViewportPoint(candidate.TargetPart.Position)
                if onScreen then
                    line.From = screenCenter
                    line.To = Vector2.new(screenPos.X, screenPos.Y)
                    line.Visible = true
                else
                    line.Visible = false
                end
            else
                line.Visible = false
            end
        end
    else
        for i = 1, 3 do TracerLines[i].Visible = false end
    end
    
    -- WalkSpeed
    if WalkSpeedEnabled and localCharacter then
        local humanoid = localCharacter:FindFirstChildOfClass("Humanoid")
        if humanoid then humanoid.WalkSpeed = CustomWalkSpeed end
    end

    -- Cập nhật FPS/Ping chỉ khi bảng đang hiển thị (tối ưu hiệu suất)
    if ShowStatsPanel then
        frameCount = frameCount + 1
        local now = os.clock()
        if now - lastUpdate >= 0.5 then
            FpsLabel.Text = "FPS: " .. math.floor(frameCount / (now - lastUpdate))
            PingLabel.Text = "PING: " .. math.max(0, math.floor(LocalPlayer:GetNetworkPing() * 1000)) .. " ms"
            frameCount = 0
            lastUpdate = now
        end
    end
end)

