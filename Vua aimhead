local function createTabBtn(name, textTable, order)
    local btn = Instance.new("TextButton")
    btn.Parent = Sidebar
    btn.Size = UDim2.new(1, -10, 0, 32)
    btn.Position = UDim2.new(0, 5, 0, 10 + (order * 36))
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 13
    btn.ZIndex = 3
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn
    
    local function updateTabStyle()
        btn.Text = (CurrentLanguage == "VN") and textTable.VN or textTable.EN
        if CurrentTab == name then
            btn.BackgroundColor3 = AccentColor
            btn.BackgroundTransparency = 0.2
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            btn.BackgroundColor3 = CardColor
            btn.BackgroundTransparency = 0.6
            btn.TextColor3 = Color3.fromRGB(200, 200, 205)
        end
    end
    
    btn.MouseButton1Click:Connect(function()
        CurrentTab = name
        for _, page in pairs(Pages) do page.Visible = false end
        Pages[name].Visible = true
        for _, func in ipairs(UI_Elements) do func() end
    end)
    
    table.insert(UI_Elements, updateTabStyle)
    updateTabStyle()
end

