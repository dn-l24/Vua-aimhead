local function createActionBtn(parentPage, texts, callback)
    local btn = Instance.new("TextButton")
    btn.Parent = parentPage
    btn.Size = UDim2.new(1, -5, 0, 30)
    btn.BackgroundColor3 = CardColor
    btn.BackgroundTransparency = 0.4
    btn.Font = Enum.Font.SourceSans
    btn.TextColor3 = Color3.fromRGB(240, 240, 240)
    btn.TextSize = 13
    btn.ZIndex = 3
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn
    
    local function updateView()
        if type(texts) == "table" then
            btn.Text = (CurrentLanguage == "VN") and texts.VN or texts.EN
        elseif type(texts) == "function" then
            btn.Text = texts()
        end
    end
    
    btn.MouseButton1Click:Connect(function() callback(btn) end)
    table.insert(UI_Elements, updateView)
    updateView()
end


