-- HỆ THỐNG ĐA NGÔN NGỮ & PHÂN LOẠI
local UI_Elements = {} 

local function createGroupHeader(texts, pos)
    local header = Instance.new("TextLabel")
    header.Parent = Container
    header.Size = UDim2.new(0, 200, 0, 20)
    header.Position = pos
    header.BackgroundTransparency = 1
    header.Font = Enum.Font.SourceSansBold
    header.TextSize = 13
    header.TextColor3 = Color3.fromRGB(0, 215, 255)
    header.TextXAlignment = Enum.TextXAlignment.Left
    header.ZIndex = 3
    
    local function updateView()
        header.Text = "--- " .. ((CurrentLanguage == "VN") and texts.VN or texts.EN) .. " ---"
    end
    updateView()
    table.insert(UI_Elements, updateView)
    return header
end

local function createToggle(name, texts, pos, defaultState, callback)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Parent = Container
    btn.Size = UDim2.new(0, 200, 0, 30)
    btn.Position = pos
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.ZIndex = 3
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = btn

    local state = defaultState
    local function updateView()
        if state then
            btn.Text = (CurrentLanguage == "VN") and texts.VN_ON or texts.EN_ON
            btn.BackgroundColor3 = Color3.fromRGB(0, 170, 100)
        else
            btn.Text = (CurrentLanguage == "VN") and texts.VN_OFF or texts.EN_OFF
            btn.BackgroundColor3 = Color3.fromRGB(170, 50, 50)
        end
    end
    updateView()

    btn.MouseButton1Click:Connect(function()
        state = not state
        updateView()
        callback(state)
    end)
    
    table.insert(UI_Elements, updateView)
    return btn
end

local function createActionBtn(texts, pos, callback)
    local btn = Instance.new("TextButton")
    btn.Parent = Container
    btn.Size = UDim2.new(0, 200, 0, 25)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextColor3 = Color3.fromRGB(220, 220, 220)
    btn.TextSize = 13
    btn.ZIndex = 3
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = btn
    
    local function updateView()
        if type(texts) == "table" then
            btn.Text = (CurrentLanguage == "VN") and texts.VN or texts.EN
        elseif type(texts) == "function" then
            btn.Text = texts()
        end
    end
    updateView()
    
    btn.MouseButton1Click:Connect(function()
        callback(btn)
    end)
    
    table.insert(UI_Elements, updateView)
    return btn
end

